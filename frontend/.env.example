# =============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================

# URL pública de la app Next.js (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================
# DIRECTUS (Headless CMS / API)
# =============================================

# URL del servidor Directus (accesible desde el navegador)
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Token estático de servicio para llamadas server-side (solo en servidor)
DIRECTUS_SERVICE_TOKEN=tu_token_de_servicio_aqui

# =============================================
# MERCADO PAGO
# =============================================

# Clave pública (se expone al cliente para el SDK de MP)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Access token privado (solo servidor)
MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================
# BACKEND COMPLEMENTARIO (Node.js)
# =============================================

# URL del servicio Node.js
BACKEND_SERVICE_URL=http://localhost:4000
