# =============================================
# VARIABLES DE ENTORNO - BACKEND TELE IMPORT
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el archivo .env al repositorio.
# =============================================

# Puerto del servidor Express
PORT=4000

# URL del frontend (para URLs de retorno de Mercado Pago)
FRONTEND_URL=http://localhost:3000

# Orígenes permitidos por CORS — separados por coma si hay más de uno.
# En producción (Render): CORS_ORIGINS=https://sctechnology.vercel.app
CORS_ORIGINS=http://localhost:3000

# URL pública del backend (para el webhook de Mercado Pago)
BACKEND_URL=http://localhost:4000

# =============================================
# BASE DE DATOS MYSQL
# =============================================
# Host del servidor MySQL (en producción: IP o hostname del servidor)
DB_HOST=localhost

# Puerto MySQL (por defecto 3306)
DB_PORT=3306

# Usuario MySQL
DB_USER=root

# Contraseña MySQL (cambiar en producción)
DB_PASSWORD=

# Nombre de la base de datos (debe existir, las tablas se crean automáticamente)
DB_NAME=tele_import

# =============================================
# AUTENTICACIÓN JWT
# =============================================
# Clave secreta para firmar tokens JWT — cambiar en producción por una cadena aleatoria larga
JWT_SECRET=tele-import-dev-secret-2024

# =============================================
# MERCADO PAGO
# =============================================
# Access token de la app de MP (usar credenciales de sandbox para desarrollo)
MP_ACCESS_TOKEN=

# Clave secreta para verificar la firma de los webhooks de MP
# Configurar en el dashboard de MP > Notificaciones
MP_WEBHOOK_SECRET=

# =============================================
# (OPCIONAL) TOKEN INTERNO DE SERVICIO
# =============================================
# Token para proteger rutas internas llamadas desde el frontend server-side
# Si no se configura, las rutas internas no requieren autenticación (útil en dev)
INTERNAL_SERVICE_TOKEN=
